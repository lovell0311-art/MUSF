        private long curSelectPlayerUUID = 0;//µ±З°СЎФсЅЗЙ«µДUUID

        private readonly List<RoleEntity> roleEntityList = new List<RoleEntity>();//ЅЗЙ«КµМеБР±н
        private bool isChooseRole = false;//КЗ·сСЎФсБЛЅЗЙ«
        
        private readonly string selectCircle = "selectCircle";//СЎФс±кК¶И¦µДЧКФґГы
