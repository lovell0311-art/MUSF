        /// <summary>
        /// 小月卡 倒计时
        /// </summary>
        public void MinMothCard() 
        {
            if (minMonthCardTickAction == null)
            {
                minMonthCardTickAction = UpdateMinMonthCardTick;
            }

            minMonthCardNextTime = 1f;
            EnsureCountDownRegistered(minMonthCardTickAction);
            return;
#if false

            var nextTime = 1f;
            CountDownAction += UpdateMacMin;
            void UpdateMacMin()
            {
                if (roleEntity.MinMonthluCardTimeSpan.TotalSeconds <= 0)
                {
                    //月卡已到期
                    CountDownAction -= UpdateMacMin;
                   // Log.DebugRed($"小月卡到期 移除监听");
                    return;
                }
                if (Time.time >= nextTime)
                {
                    roleEntity.MinMonthluCardTimeSpan = roleEntity.MinMonthluCardTimeSpan.Subtract(subTimeSpan);
                    //Log.DebugGreen($"小月卡时间 -》{roleEntity.MinMonthluCardTimeSpan}");
                    UpdateMCCountDownAction?.Invoke(roleEntity.MinMonthluCardTimeSpan);
                    nextTime = Time.time + 1;
                }
            }
#endif
        }
