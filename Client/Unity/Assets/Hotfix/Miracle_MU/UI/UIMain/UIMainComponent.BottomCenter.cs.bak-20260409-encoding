            Mp.fillAmount = Ratio;
            MPValue.fillAmount = Ratio;
           // if (RoleOnHookComponent.Instance.IsOnHooking)
            {
                RoleOnHookComponent.Instance.UseMedicineMp(Ratio);
            }
        }

