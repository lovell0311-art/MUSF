        public void ShowHp(bool isShow = true)
        {
            if (hpSlider == null) return;
            if (hpSlider.maxValue == 0) hpSlider.maxValue = 100;
            hpSlider.value = hpSlider.maxValue;
            hpSlider.gameObject.SetActive(isShow);
        }

