				UNITY_SETUP_INSTANCE_ID(i);
				UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(i);
				fixed4 finalColor;
				#ifdef ASE_NEEDS_FRAG_WORLD_POSITION
				float3 WorldPosition = i.worldPos;
				#endif
				float2 appendResult9 = (float2(_NoiseTex_USpeed , _NoiseTex_VSpeed));
				float2 uv2_MainTex = i.ase_texcoord1.xy * _MainTex_ST.xy + _MainTex_ST.zw;
				float2 panner6 = ( 1.0 * _Time.y * appendResult9 + uv2_MainTex);
				float4 temp_output_30_0 = ( _BaseColor * tex2D( _MainTex, panner6 ) * i.ase_color );
				
				
				finalColor = ( temp_output_30_0 * temp_output_30_0.a );
				return finalColor;
			}
			ENDCG
