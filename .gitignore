# MUSF workspace
# Keep source, docs, configs, scripts, and templates tracked.
# Ignore generated outputs, heavy toolchains, local data, and release artifacts.

# Existing cross-project heavy directories
**/[Ll]ibrary/
**/[Ll]ogs/
**/[Oo]bj/
**/[Tt]emp/
**/[Uu]serSettings/
**/[Bb]uild/
**/[Bb]uilds/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/
**/[Nn]ode_modules/
**/[Bb]in/

# Editor / IDE caches
**/.vs/
**/.idea/
*.suo
*.user
*.userprefs

# Python caches
**/__pycache__/
*.pyc
*.pyo

# Large packaged artifacts
*.apk
*.aab
*.ipa
*.unitypackage

# Root heavy/runtime directories
/--output/
/archive/
/backups/
/baseline/
/canary-state/
/downloads/
/Excel/
/mini30_probe_export/
/MongoDB/
/reports/
/tmp/
/toolchain/
/_apktool_20260310/
/_apktool_20260310pjzr_assets/
/_manifest_check/
/_patch_work/
/codebundle_probe_export_shadow/

